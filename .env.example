# Yahoo Mail MCP Server Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git!

# Your Yahoo Mail email address
YAHOO_EMAIL=your.email@yahoo.com

# Yahoo Mail app-specific password (16 characters)
# Generate at: https://login.yahoo.com/account/security/app-passwords
# Instructions:
#   1. Go to https://login.yahoo.com/account/security
#   2. Click "Generate app password" or "Manage app passwords"
#   3. Select "Other App" and enter "MCP Server"
#   4. Copy the generated 16-character password
YAHOO_APP_PASSWORD=your16charpassword

# Optional: Yahoo's undocumented web API is required for list_filters and
# create_filter. These values must be copied from an authenticated Yahoo Mail
# /ws/v3/batch request in browser developer tools. They are NOT the app
# password and will expire when Yahoo ends the browser session.
#
# Treat the cookie as a full mailbox credential. Never commit or share it.
YAHOO_WEB_COOKIE=
YAHOO_WEB_WSSID=
YAHOO_WEB_MAILBOX_ID=

# Normally leave this at the default used by the current Yahoo Mail frontend.
YAHOO_WEB_APP_ID=YMailNovation
